PORT=8001
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_JQL_SEJ=project = SEJ ORDER BY Rank ASC
JIRA_JQL_PEJ=project = PEJ ORDER BY Rank ASC
SYNC_USERNAME=choose-a-sync-username
SYNC_PASSWORD=choose-a-strong-sync-password

# Optional: set these only if the server cannot auto-detect your Jira custom fields.
JIRA_FIELD_SPRINT=
JIRA_FIELD_STORY_POINTS=
JIRA_FIELD_DUE_DATE=
JIRA_FIELD_PRODUCT_MANAGER=
JIRA_FIELD_UNIVERSITY_NAME=
JIRA_FIELD_SKILL_SET=
JIRA_FIELD_TEST_CASE_DOC=
